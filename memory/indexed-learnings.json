  "techniques": [
    {
      "id": 0,
      "name": "Grill session before building",
      "description": "Get agent to ask detailed questions until every decision branch is resolved. Prevents misalignment (#1 failure mode).",
      "source": "mattpocock/grill-me"
    },
    {
      "id": 1,
      "name": "CONTEXT.md shared language",
      "description": "Define project jargon in one doc. Agent speaks concisely, names consistently, reduces tokens 75%.",
      "source": "mattpocock/grill-with-docs"
    },
    {
      "id": 2,
      "name": "Red-green-refactor TDD loop",
      "description": "Write failing test → minimal fix → refactor. Applied to SKILLS: test with pressure scenarios → write skill → refine.",
      "source": "mattpocock/tdd + superpowers/writing-skills"
    },
    {
      "id": 3,
      "name": "Diagnose loop",
      "description": "reproduce → minimise → hypothesise → instrument → fix → regression-test.",
      "source": "mattpocock/diagnose"
    },
    {
      "id": 4,
      "name": "Architecture deepening",
      "description": "Run regularly to find 'deepening opportunities' — places where code can be made simpler via better abstractions.",
      "source": "mattpocock/improve-codebase-architecture"
    },
    {
      "id": 5,
      "name": "Setup skill pattern",
      "description": "One-time setup skill asks user preferences, creates config file, all other skills consume that config.",
      "source": "mattpocock/setup-matt-pocock-skills"
    },
    {
      "id": 6,
      "name": "Handoff document",
      "description": "Compact current conversation into structured doc for agent continuation.",
      "source": "mattpocock/handoff"
    },
    {
      "id": 7,
      "name": "Caveman compression",
      "description": "Communication mode that drops all filler, keeps technical accuracy. 75% token reduction.",
      "source": "mattpocock/caveman"
    },
    {
      "id": 8,
      "name": "SkillOpt training loop",
      "description": "rollout-reflect-aggregate-select-update-evaluate.",
      "source": "microsoft/SkillOpt"
    },
    {
      "id": 9,
      "name": "Skill validation script",
      "description": "Automated checks: frontmatter, lines, sections, code, placeholders.",
      "source": "self-developed"
    },
    {
      "id": 10,
      "name": "Identity-Instructions-Examples-Context",
      "description": "Structure every generated prompt in this order. Identity first (role/purpose), then rules, then few-shot examples, then dynamic context data. Proven by OpenAI and Anthropic to maximize instruction adherence.",
      "source": "OpenAI + Anthropic 2024-2026"
    },
    {
      "id": 11,
      "name": "Atomic prompt iteration",
      "description": "Change one thing at a time in a skill prompt. Measure before/after. Keep or revert. Never batch-edit prompts without measurement.",
      "source": "OpenAI + skill-creator eval methodology"
    },
    {
      "id": 12,
      "name": "Composable agent patterns",
      "description": "5 building blocks: prompt chaining, routing, parallelization, orchestrator-workers, evaluator-optimizer. Start simple, add complexity only when measured improvement.",
      "source": "Anthropic building effective agents (Dec 2024)"
    }
  ],
  "philosophies": [
    {
      "id": 0,
      "text": "Skills for Real Engineers. Not vibe coding.",
      "source": "mattpocock/skills"
    },
    {
      "id": 1,
      "text": "Software engineering fundamentals matter more than ever. Skills condense fundamentals into repeatable practices.",
      "source": "mattpocock/skills"
    },
    {
      "id": 2,
      "text": "Developing real applications is hard. Approaches that OWN the process take away control. Skills should be small, easy to adapt, composable.",
      "source": "mattpocock/skills"
    },
    {
      "id": 3,
      "text": "The rate of feedback is your speed limit. Never take on a task that's too big.",
      "source": "Pragmatic Programmer via mattpocock"
    },
    {
      "id": 4,
      "text": "Invest in the design of the system every day.",
      "source": "Kent Beck via mattpocock"
    },
    {
      "id": 5,
      "text": "The best modules are deep: a lot of functionality through a simple interface.",
      "source": "Ousterhout via mattpocock"
    },
    {
      "id": 6,
      "text": "A ubiquitous language makes conversations among developers derived from the same domain model.",
      "source": "DDD/Eric Evans via mattpocock"
    },
    {
      "id": 7,
      "text": "Skills encode the workflows that senior engineers use — packaged for AI agents",
      "source": "addyosmani/agent-skills"
    },
    {
      "id": 8,
      "text": "Treat the skill document as the trainable state of a frozen agent",
      "source": "microsoft/SkillOpt"
    },
    {
      "id": 9,
      "text": "A skill's quality is measured by the BEHAVIOR it produces, not the text it contains",
      "source": "self-learned cycle 2"
    }
  ]
}